<!--
  Target window markup. This is the window the Test Bench control panel drives.

  It intentionally does NOT set Window.Width / Height in markup: those XAML
  attributes don't exist in the public Windows App SDK yet. The initial size is
  applied from code-behind instead. The Window.Width / Height *code* API is
  compiled in only behind the SupportWindowWidthHeight feature flag (see
  MyApp.csproj and the #if'd helpers in MainWindow.xaml.cs).
-->
<Window
    x:Class="MyApp.TargetWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MyApp"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="24">
        <StackPanel Spacing="12" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Target Window" Style="{StaticResource TitleTextBlockStyle}" HorizontalAlignment="Center" />
            <TextBlock TextWrapping="Wrap" TextAlignment="Center" MaxWidth="520"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="This window is driven by the Test Bench control panel. Use the controls there to move, resize, change z-order, presenter, title bar and visibility of this window." />
        </StackPanel>
    </Grid>
</Window>
