<!--
  Target window markup for Windows App SDK 3.0+.
  Demonstrates markup that only the newer WASDK can parse: Window.Width / Height
  set directly as attributes. MSBuild selects this file when the project's
  WindowsAppSDKVersion has a major version >= 3 (see MyApp.csproj).
-->
<Window
    x:Class="MyApp.TargetWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MyApp"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Width="900"
    Height="640">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="24">
        <StackPanel Spacing="12" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Target Window" Style="{StaticResource TitleTextBlockStyle}" HorizontalAlignment="Center" />
            <TextBlock TextWrapping="Wrap" TextAlignment="Center" MaxWidth="520"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="This window is driven by the Test Bench control panel. Use the controls there to move, resize, change z-order, presenter, title bar and visibility of this window." />
            <TextBlock Text="(...)"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" FontSize="12"
                       HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</Window>
